# Example environment file for CAIPE DeepEval Evaluation service.
# Copy this file to .env for local or container deployment.

# ==========================================
# LLM Proxy / OpenAI-Compatible API Gateway
# ==========================================
OPENAI_API_KEY="sk-your-openai-or-lite-llm-proxy-key"
OPENAI_ENDPOINT="https://api.openai.com/v1"
OPENAI_MODEL_NAME="bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0"
EMBEDDINGS_MODEL="bedrock/amazon.titan-embed-text-v2:0"

# ==========================================
# CAIPE System Endpoints
# ==========================================
CAIPE_SUPERVISOR_URL="https://caipe.homelab"
CAIPE_BASE_URL="https://rag.caipe.homelab"
INSECURE_SSL="true"

# ==========================================
# CAIPE DeepEval REST API Authorization
# ==========================================
DEEPEVAL_API_KEY="caipe-deepeval-auth-secret-key-12345"

# ==========================================
# PostgreSQL Database Persistence Configuration
# ==========================================
POSTGRES_HOST="192.168.8.132"
POSTGRES_PORT="30543"
POSTGRES_DB="caipe_eval"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-secure-postgres-password"
DATABASE_URL="postgresql://postgres:your-secure-postgres-password@192.168.8.132:30543/caipe_eval"

# ==========================================
# Dataset paths & DataSource IDs
# ==========================================
# Enterprise RAG Bench
ENTERPRISE_RAGAS_DATASOURCE="enterprise_rag_bench"
ENTERPRISE_CAIPE_DATASOURCE_ID="enterprise_rag_bench"
ENTERPRISE_QUESTIONS_PATH="/app/data/enterprise_rag_bench_questions.jsonl"
ENTERPRISE_RAG_EVAL_PROMPT_STYLE="generation" # Options: "generation" (default/detailed) or "short"

# HotpotQA
HOTPOTQA_CAIPE_DATASOURCE_ID="hotpotqa_sample"
HOTPOTQA_RAGAS_DATASOURCE="hotpotqa"
HOTPOTQA_QUESTIONS_PATH="/app/data/hotpotqa_full_questions.jsonl"
RAG_EVAL_PROMPT_STYLE="short" # Options: "generation" or "short"

