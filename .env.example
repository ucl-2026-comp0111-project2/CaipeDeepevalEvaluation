# Example environment file for local DeepEval runs.
# Copy this to .env only for local use, and never commit real credentials.

# LLM Proxy / OpenAI-compatible gateway used for answer generation
# and DeepEval judge calls.
OPENAI_API_KEY=replace-with-api-key
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_MODEL_NAME=azure/gpt-5.4

# CAIPE rag-server defaults to http://localhost:9446 in the scripts.
# To use a different rag-server URL, pass --rag-url when running a script.
